{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "portfolio",
  "description": "V0.7 — gh/claude CLI 위임 (bash -lc login 셸 PATH fix) + curl/zip/open (sh -lc) + 스크린샷 binary write + dotfile (.synced.md, .trash/) scope",
  "windows": ["main"],
  "permissions": [
    "shell:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "sh",
          "cmd": "sh",
          "args": true,
          "sidecar": false
        },
        {
          "name": "bash",
          "cmd": "bash",
          "args": true,
          "sidecar": false
        }
      ]
    },
    "fs:allow-write-file",
    {
      "identifier": "fs:scope",
      "allow": [
        { "path": "$HOME/**/.*" },
        { "path": "$HOME/**/.*/**" }
      ]
    }
  ]
}
